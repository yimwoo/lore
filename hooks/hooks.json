{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/run-session-start.sh",
            "statusMessage": "Loading Lore shared knowledge"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node --import tsx src/plugin/pre-prompt-whisper.ts",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node --import tsx src/plugin/stop-observer.ts",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}
